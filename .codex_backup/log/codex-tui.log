+  const tier = getPriceTier(item.category, item.price);
+
+  if (rating >= 4 || tier === "high") return "ok";
+  if (rating <= 2 && tier === "low") return "error";
+  return "warning";
+};
+
+const getCategoryPerformance = (item) => {
+  const product = getSelectedProduct(item);
