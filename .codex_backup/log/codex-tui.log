     size=None; print('ERR',type(e).__name__,e)\n        if size:\n            w,h=size; ratio=round(w/h,2)\n        else: w=h=ratio='?'\n        print(p['id'], w,h,ratio, p['name'][:55])\nPY","workdir":"/home/ajrqh1030/test/GOREON","yield_time_ms":1000,"max_output_tokens":20000} thread_id=019db45c-209c-73f2-918d-955f73332314
